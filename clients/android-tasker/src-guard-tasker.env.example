GUARD_URL="http://192.168.1.10:22368"
TOKEN="change-me-to-a-long-random-token"

# Optional. When omitted, the script uses this device's name/model/hostname.
# CLIENT="Pixel 8 Pro"

# How long one lock lasts on the guard. Default is 360 minutes / 6 hours.
DURATION="360"

# Client-side debounce before sending stop. This protects short background switches.
HOLD_SECONDS="45"
